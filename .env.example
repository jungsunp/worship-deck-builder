# Copy to .env and fill in. .env is git-ignored.

# Anthropic API — used to transcribe lyrics from band/choir sheet images (Claude vision)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# ESV API — free, non-commercial. Get a key at https://api.esv.org/
ESV_API_KEY=

# Paths (defaults assume iCloud Drive). Override as needed.
INBOX_DIR=~/Library/Mobile Documents/com~apple~CloudDocs/NPC-Worship/inbox
TEMPLATE_KEY=~/projects/npc-worship-deck/templates/master.key
HYMN_LIBRARY_DIR=~/projects/npc-worship-deck/data/hymns

# Web app
WEB_HOST=127.0.0.1
WEB_PORT=8787
